{
  "expo": {
    "name": "Poop Timer",
    "slug": "poop-timer",
    "version": "1.0.0",
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#2f7d5b"
        }
      ]
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#f7f1df"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f7f1df"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.pooptimer"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
